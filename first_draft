#Marital Status and Physcial Activiy 
brfs$MARITAL <- as.factor(brfs$MARITAL)

brfs_1 <- brfs%>%
  filter(MARITAL!='9', !is.na(PA1MIN_))

#Q4: Remove Outliers. Remaining Data 
PA_upper <- quantile(brfs_1$PA1MIN_, 0.997, na.rm = TRUE)

PA_lower <- quantile(brfs_1$PA1MIN_, 0.003, na.rm = TRUE)

lower <- round(PA_lower,2)

PA_outliers <- which(brfs_1$PA1MIN_ > PA_upper | brfs_1$PA1MIN_ < lower)

remain <- (nrow(brfs_1) - length(PA_outliers))/ nrow(brfs_1)*100
Q4 <- round(remain,2)

#Take Outliers out of Data
brfs_noOut <- brfs_1[-PA_outliers,]

#Q5:Group by marital status and calculate the mean, standard deviation, minimum, and maximum of total exercise, to two decimals.
Q5 <- brfs_noOut%>%
  group_by(MARITAL)%>%
  summarise(mean_PA = round(mean(PA1MIN_),2), 
            sd_PA = round(sd(PA1MIN_), 2),
            min_PA = round(min(PA1MIN_),2),
            max_PA = round(max(PA1MIN_),2))

#Q6: Create a boxplot for total exercise by marital status.
Q6 <-boxplot(PA1MIN_~MARITAL, data=brfs_noOut, main="Total Exercise by Marital Status",
             xlab="Marital Status", ylab="Minutes of Exercise per Week")

#Q7: Run a regression predicting exercise by marital status. Assign the model summary to Q7.
reg1 <- lm(PA1MIN_ ~ MARITAL, data = brfs_noOut)
Q7 <- summary(reg1)

#Q8:Run an ANOVA comparing exercise across marital status, and assign the TukeyHSD post-hoc test to Q8.
av1 <- aov(PA1MIN_ ~ MARITAL, data= brfs_noOut)
Q8 <- TukeyHSD(av1)

